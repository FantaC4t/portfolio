---
const groups: { label: string; chips: { name: string; color: string }[] }[] = [
  {
    label: 'lang',
    chips: [
      { name: 'Java', color: '#ffaa6b' },
      { name: 'JavaScript', color: '#ff85b3' },
      { name: 'TypeScript', color: '#5b9dfa' },
      { name: 'Python', color: '#ffe066' },
      { name: 'SQL', color: '#5ccfcf' },
      { name: 'C#', color: '#a78bfa' },
    ],
  },
  {
    label: 'web',
    chips: [
      { name: 'HTML & CSS', color: '#ff8c69' },
      { name: 'Astro', color: '#c084fc' },
      { name: 'Firebase', color: '#ff85b3' },
      { name: 'Cloudflare Workers', color: '#ffe066' },
    ],
  },
  {
    label: 'tools',
    chips: [
      { name: 'Git', color: '#a78bfa' },
      { name: 'Gradle', color: '#ff8c69' },
      { name: 'Nix', color: '#7ebae4' },
    ],
  },
  {
    label: 'game',
    chips: [
      { name: 'Fabric API', color: '#ffaa6b' },
      { name: 'Unity', color: '#5ccfcf' },
    ],
  },
];
---

<section class="section" id="skills">
  <div class="section-head reveal">
    <h2 class="section-title"><span class="sec-num">&sect; ii</span>skills</h2>
  </div>

  <div class="skills-grid">
    {groups.map((g) => (
      <div class="skill-card reveal">
        <div class="card-head term-head mono"><span class="term-dots"><i></i><i></i><i></i></span><span>~/skills/{g.label}</span></div>
        <div class="chip-row">
          {g.chips.map((c) => (
            <span class="chip" style={`--c:${c.color}`}>{c.name}</span>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.9rem;
  }
  @media (max-width: 640px) {
    .skills-grid { grid-template-columns: 1fr; }
  }

  .skill-card {
    position: relative;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: 0 1.15rem 1.15rem;
    overflow: hidden;
    transition: border-color 0.2s;
  }
  .skill-card:hover { border-color: rgba(255, 140, 40, 0.4); }
  .skill-card .card-head { margin: 0 -1.15rem 0.85rem; }

  .chip-row { display: flex; gap: 0.45rem; flex-wrap: wrap; }
  .chip {
    font-size: 0.8rem;
    padding: 0.32rem 0.7rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--c, var(--line));
    color: var(--ink);
    background: color-mix(in srgb, var(--c, var(--line)) 14%, var(--surface));
  }
</style>
