---
import { Image } from 'astro:assets';
import profile from '../assets/profile.png';
import OrnamentDivider from './OrnamentDivider.astro';
---

<div class="ticker mono">
  <span class="live-dot" aria-hidden="true"></span>
  <span id="live-push">checking latest push&hellip;</span>
  <i class="dia sep" aria-hidden="true"></i>
  <span class="discord-status">
    <span class="discord-dot" id="discord-status-dot" aria-hidden="true"></span>
    <span id="discord-status-text">@fantacat</span>
  </span>
</div>

<header class="hero">
  <div class="frame" aria-hidden="true">
    <span class="bracket tl"></span><span class="bracket br"></span>
  </div>

  <div class="hero-inner">
    <div class="portrait" data-tilt>
      <div class="portrait-frame" aria-hidden="true">
        <span class="p-bracket tl"></span><span class="p-bracket tr"></span>
        <span class="p-bracket bl"></span><span class="p-bracket br"></span>
      </div>
      <Image src={profile} alt="fantacat" width={240} height={240} format="webp" quality={85} loading="eager" />
    </div>

    <div class="hero-text">
      <span class="eyebrow mono"><i class="dia" aria-hidden="true"></i>dev &amp; server owner</span>
      <h1 class="name">fanta<span class="accent">cat</span><span class="caret" aria-hidden="true"></span></h1>
      <p class="sub">I write code, break things, fix them<em> &mdash; and run the tech behind TSNSMP.</em></p>
      <div class="cta-row">
        <a class="btn btn-primary copy-email-btn" href="mailto:vanushka060@gmail.com">say hi <span class="btn-arrow" aria-hidden="true">&#8594;</span></a>
        <a class="btn btn-ghost" href="#projects">view projects</a>
      </div>

      <div class="socials">
        <a href="https://www.twitch.tv/fantac4t" target="_blank" rel="noopener" class="social-btn" style="--sc:#9146ff" title="Twitch" aria-label="Twitch">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M11.64 5.93h1.43v4.28h-1.43m3.93-4.28H17v4.28h-1.43M7 2L3.43 5.57v12.86h4.28V22l3.58-3.57h2.85L20.57 12V2m-1.43 9.29l-2.85 2.85h-2.86l-2.5 2.5v-2.5H7.71V3.43h11.43z"/></svg>
        </a>
        <a href="https://github.com/fantac4t" target="_blank" rel="noopener" class="social-btn" style="--sc:#e0e0e0" title="GitHub" aria-label="GitHub">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        </a>
        <a href="https://discord.gg/B4pKwswkVE" target="_blank" rel="noopener" class="social-btn" style="--sc:#5865f2" title="Discord" aria-label="Discord">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028 14.09 14.09 0 001.226-1.994.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03z"/></svg>
        </a>
        <a href="https://bsky.app/profile/fantacat.net" target="_blank" rel="noopener" class="social-btn" style="--sc:#0085ff" title="Bluesky" aria-label="Bluesky">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.815 2.736 3.713 3.66 6.383 3.364.136-.02.275-.039.415-.056-.138.022-.276.04-.415.056-3.912.58-7.387 2.005-2.83 7.078 5.013 5.19 6.87-1.113 7.823-4.308.953 3.195 2.05 9.271 7.733 4.308 4.267-4.308 1.172-6.498-2.74-7.078a8.741 8.741 0 01-.415-.056c.14.017.279.036.415.056 2.67.297 5.568-.628 6.383-3.364.246-.828.624-5.79.624-6.478 0-.69-.139-1.861-.902-2.204-.659-.299-1.664-.62-4.3 1.24C16.046 4.748 13.087 8.687 12 10.8z"/></svg>
        </a>
      </div>
    </div>
  </div>

  <div class="hero-orn">
    <OrnamentDivider id="orn-hero" size="lg" />
  </div>
</header>

<style>
  .ticker {
    position: sticky;
    top: 0;
    z-index: 30;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    background: var(--surface);
    font-size: 0.72rem;
    color: var(--ink-dim);
    padding: 0.6rem 1.5rem;
    display: flex;
    gap: 0.6rem;
    align-items: center;
    flex-wrap: wrap;
    letter-spacing: 0.01em;
  }
  .ticker .sep { opacity: 0.4; }
  .ticker :global(.ticker-link) {
    color: var(--accent-bright);
    text-decoration: none;
    border-bottom: 1px dashed color-mix(in srgb, var(--accent-bright) 55%, transparent);
  }
  .ticker :global(.ticker-link:hover) { color: var(--gold-bright); }

  .hero {
    position: relative;
    padding: 3.2rem 1.5rem 1.2rem;
    max-width: var(--max-width);
    margin: 0 auto;
    overflow: hidden;
  }
  .hero-orn {
    position: relative;
    z-index: 2;
    margin-top: 1.8rem;
  }
  .hero-orn :global(.ornament-wrap) { padding: 0; }
  .frame { position: absolute; inset: 1.1rem; pointer-events: none; z-index: 1; }
  .bracket { position: absolute; width: 26px; height: 26px; border-color: var(--gold-bright); opacity: 0.85; }
  .bracket.tl { top: 0; left: 0; border-top: 2px solid; border-left: 2px solid; }
  .bracket.br { bottom: 0; right: 0; border-bottom: 2px solid; border-right: 2px solid; }
  .bracket::after {
    content: '';
    position: absolute;
    width: 5px;
    height: 5px;
    background: var(--accent-bright);
    transform: rotate(45deg);
    box-shadow: 0 0 7px rgba(255, 115, 0, 0.85);
  }
  .bracket.tl::after { top: -2.5px; left: -2.5px; }
  .bracket.br::after { bottom: -2.5px; right: -2.5px; }

  .hero-inner {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 1.8rem;
    flex-wrap: wrap;
  }

  .portrait {
    position: relative;
    flex: none;
    width: 132px;
    height: 132px;
    border-radius: var(--radius-md);
    overflow: visible;
    transition: transform 0.15s ease;
  }
  .portrait :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--radius-md);
    display: block;
    box-shadow: 0 14px 40px -14px rgba(0, 0, 0, 0.7);
  }
  .portrait-frame { position: absolute; inset: -7px; pointer-events: none; }
  .p-bracket { position: absolute; width: 16px; height: 16px; border-color: var(--gold-bright); }
  .p-bracket.tl { top: 0; left: 0; border-top: 2px solid; border-left: 2px solid; }
  .p-bracket.tr { top: 0; right: 0; border-top: 2px solid; border-right: 2px solid; }
  .p-bracket.bl { bottom: 0; left: 0; border-bottom: 2px solid; border-left: 2px solid; }
  .p-bracket.br { bottom: 0; right: 0; border-bottom: 2px solid; border-right: 2px solid; }

  .hero-text { flex: 1 1 24rem; min-width: 0; }
  .eyebrow {
    font-size: 0.75rem;
    color: var(--accent-bright);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    margin-bottom: 1.05rem;
  }
  .eyebrow::before {
    content: '';
    width: 18px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold-dim));
    opacity: 0.9;
  }

  .name {
    font-size: clamp(2.6rem, 6.8vw, 4.4rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 0.98;
    margin-bottom: 0.85rem;
    color: var(--gold-bright);
    text-shadow: 0 0 46px rgba(255, 122, 30, 0.32), 0 0 90px rgba(255, 122, 30, 0.22);
  }
  .name .accent {
    background: linear-gradient(
      110deg,
      var(--accent) 0%, var(--gold-bright) 28%, var(--accent) 55%, var(--accent-warm) 80%, var(--accent) 100%
    );
    background-size: 260% auto;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    animation: shimmer 8s ease-in-out infinite;
  }
  @keyframes shimmer {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }
  @media (prefers-reduced-motion: reduce) { .name .accent { animation: none; } }

  .caret {
    display: inline-block;
    width: 3px;
    height: 0.78em;
    background: var(--accent-bright);
    margin-left: 3px;
    vertical-align: -0.04em;
    box-shadow: 0 0 8px rgba(255, 115, 0, 0.75);
    animation: blink 1.05s steps(1) infinite;
  }
  @keyframes blink { 50% { opacity: 0; } }
  @media (prefers-reduced-motion: reduce) { .caret { animation: none; } }

  .sub { font-size: 1.04rem; color: var(--ink-dim); max-width: 31rem; line-height: 1.65; margin-bottom: 0.85rem; }
  .sub em { font-family: var(--font-serif); font-style: italic; font-weight: 500; color: var(--accent-bright); }

  .cta-row { margin-top: 1.2rem; }

  .socials { display: flex; gap: 0.6rem; margin-top: 1.1rem; }
  .social-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: var(--radius-sm);
    background: var(--surface);
    border: 1px solid var(--line);
    color: var(--ink-dim);
    transition: background 0.2s, border-color 0.2s, color 0.2s, transform 0.2s;
  }
  .social-btn svg { width: 18px; height: 18px; }
  .social-btn:hover {
    background: color-mix(in srgb, var(--sc) 16%, transparent);
    border-color: color-mix(in srgb, var(--sc) 55%, transparent);
    color: var(--sc);
    transform: translateY(-2px);
  }

  @media (max-width: 640px) {
    .hero-inner { flex-direction: column; align-items: flex-start; text-align: left; }
  }
</style>
