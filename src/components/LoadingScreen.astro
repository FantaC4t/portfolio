    vertical-align: -0.04em;
    box-shadow: 0 0 8px rgba(255, 115, 0, 0.75);
    animation: blink 1.05s steps(1) infinite;
  }
  @keyframes blink { 50% { opacity: 0; } }

  .loader-bar {
    width: 84px;
